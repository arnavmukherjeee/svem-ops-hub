        <script><![CDATA[(function executeRule(current, previous) {
    if (!current.employee_id || current.employee_id == '') {
        var prefix = 'EMP';
        var gr = new GlideAggregate('x_1964226_svem_com_staff');
        gr.addAggregate('COUNT');
        gr.query();
        var count = 0;
        if (gr.next()) {
            count = parseInt(gr.getAggregate('COUNT')) || 0;
        }
        var nextNum = count + 1;
        current.employee_id = prefix + '-' + ('000' + nextNum).slice(-3);
    }
})(current, previous);]]></script>
